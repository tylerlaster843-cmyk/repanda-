# Enable or disable --emit-relocs for the redpanda binary (only)
bool_flag(
    name = "emit_relocs",
    build_setting_default = False,
)

config_setting(
    name = "use_emit_relocs",
    flag_values = {
        ":emit_relocs": "true",
    },
    visibility = ["//visibility:public"],
)

redpanda_cc_binary(
    name = "redpanda",
    srcs = [
        "main.cc",
    ],
    linkopts =
        select({
            ":use_emit_relocs": [
                "-Wl,--emit-relocs",
            ],
            "//conditions:default": [
            ],
        }),
    visibility = ["//visibility:public"],
    deps = [
        ":application",
        "//src/v/syschecks",
    ],
)

